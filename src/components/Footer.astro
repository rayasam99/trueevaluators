---
const serviceLinks = [
  { label: 'Academic Evaluation',        href: '/services/academic-evaluation' },
  { label: 'Work Experience Evaluation', href: '/services/work-experience-evaluation' },
  { label: 'Expert Opinion Letters',     href: '/services/expert-opinion-letter' },
  { label: 'LCA Analysis',               href: '/services/lca-analysis' },
  { label: 'CPT Analysis',               href: '/services/cpt-analysis' },
  { label: 'Integrated Expert Opinion',  href: '/services/integrated-expert-opinion' },
];

const otherLinks = [
  { label: 'Home',        href: '/' },
  { label: 'About',       href: '/about' },
  { label: 'Services',    href: '/services' },
  { label: 'Methodology', href: '/methodology' },
  { label: 'Pricing',     href: '/pricing' },
  { label: 'Contact',     href: '/contact' },
];
---

<footer class="site-footer">
  <div class="footer-top">
    <div class="container footer-grid">

      <!-- Brand Column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="True Evaluators Home">
          <img src="/True-E-White.png" alt="True Evaluators" class="footer-logo-img" />
        </a>

        <p class="footer-desc">
          True Evaluators is a trusted provider of immigration support, specializing in
          accurate evaluations, expert opinions, and customized solutions for success.
        </p>

        <div class="social-links" aria-label="Social media links">
          <a href="#" class="social-icon" aria-label="Facebook" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="#" class="social-icon" aria-label="Twitter" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
              <path d="M4 4h4l3 4 4-4h4L13 12l6 8h-4l-4-5-4 5H3l6-8L4 4z"/>
            </svg>
          </a>
          <a href="#" class="social-icon" aria-label="Instagram" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a href="#" class="social-icon" aria-label="LinkedIn" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Our Location -->
      <div class="footer-col">
        <h4 class="footer-heading">Our Location</h4>
        <div class="footer-location-item">
          <span class="footer-location-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </span>
          <span>1580 Sawgrass Corporate Pkwy, Suite 130 Sunrise, FL 33323</span>
        </div>

        <h4 class="footer-heading" style="margin-top: 1.5rem;">Book Your Session</h4>
        <div class="footer-location-item">
          <span class="footer-location-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
              <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
              <line x1="12" y1="18" x2="12.01" y2="18"/>
            </svg>
          </span>
          <a href="tel:+13054899346" class="footer-phone">(305) 489-9346</a>
        </div>
      </div>

      <!-- Other Pages -->
      <div class="footer-col">
        <h4 class="footer-heading">Other Pages</h4>
        <ul>
          {otherLinks.map(l => (
            <li>
              <a href={l.href} class="footer-link">
                <svg viewBox="0 0 8 12" fill="none" width="7" height="11" aria-hidden="true">
                  <path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h4 class="footer-heading">Services</h4>
        <ul>
          {serviceLinks.map(l => (
            <li>
              <a href={l.href} class="footer-link">
                <svg viewBox="0 0 8 12" fill="none" width="7" height="11" aria-hidden="true">
                  <path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>Copyright &copy; {new Date().getFullYear()} True Evaluators</p>
      <div class="footer-bottom-links">
        <a href="/privacy-policy">Privacy Policy</a>
        <span aria-hidden="true">|</span>
        <a href="/terms-of-service">Terms &amp; Conditions</a>
        <span aria-hidden="true">|</span>
        <a href="/disclaimer">Disclaimer Policy</a>
      </div>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--clr-primary-dark);
  color: rgba(255,255,255,0.7);
}

.footer-top {
  padding-block: clamp(2.5rem, 5vw, 4rem);
}

.footer-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
}
@media (min-width: 640px)  { .footer-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .footer-grid { grid-template-columns: 1.8fr 1.2fr 1fr 1.2fr; } }

/* Brand */
.footer-logo {
  display: inline-block;
  margin-bottom: 1.1rem;
  text-decoration: none;
}
.footer-logo-img {
  height: 52px;
  width: auto;
  display: block;
}

.footer-desc {
  font-size: 0.82rem;
  line-height: 1.75;
  color: rgba(255,255,255,0.55);
  margin-bottom: 1.4rem;
  max-width: 280px;
}

/* Social */
.social-links {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.social-icon {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.65);
  transition: background var(--ease), color var(--ease), transform var(--ease);
}
.social-icon:hover {
  background: var(--clr-primary);
  color: var(--clr-white);
  border-color: var(--clr-primary);
  transform: translateY(-2px);
}

/* Location column */
.footer-location-item {
  display: flex;
  gap: 0.65rem;
  align-items: flex-start;
  font-size: 0.82rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.6;
}
.footer-location-icon {
  flex-shrink: 0;
  color: var(--clr-primary);
  margin-top: 1px;
}
.footer-phone {
  color: rgba(255,255,255,0.55);
  transition: color var(--ease);
}
.footer-phone:hover { color: var(--clr-white); }

/* Columns */
.footer-heading {
  font-family: var(--font-body);
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--clr-white);
  margin-bottom: 1rem;
}
.footer-link {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.83rem;
  color: rgba(255,255,255,0.55);
  padding: 0.25rem 0;
  transition: color var(--ease), padding-left var(--ease);
}
.footer-link svg { flex-shrink: 0; opacity: 0.6; }
.footer-link:hover {
  color: var(--clr-white);
  padding-left: 3px;
}
.footer-link:hover svg { opacity: 1; }

/* Bottom */
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-block: 1rem;
}
.footer-bottom-inner {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  align-items: center;
  text-align: center;
  font-size: 0.78rem;
  color: rgba(255,255,255,0.4);
}
.footer-bottom-links {
  display: flex;
  gap: 0.5rem;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
}
.footer-bottom-links a {
  color: rgba(255,255,255,0.4);
  transition: color var(--ease);
}
.footer-bottom-links a:hover { color: var(--clr-white); }

@media (min-width: 640px) {
  .footer-bottom-inner {
    flex-direction: row;
    justify-content: space-between;
    text-align: left;
  }
}
</style>
