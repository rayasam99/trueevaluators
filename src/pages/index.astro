---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="True Evaluators – Industry-Expert Credential Evaluation Services"
  description="Industry-expert credential evaluation services for international professionals. Academic evaluation, work experience, expert opinion, ECA, CPT analysis, and more."
>

  <!-- ============================================================
       SECTION 1 — HERO
       ============================================================ -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="eyebrow">Trusted Since 2019</span>
        <h1 class="hero-heading">
          Industry-Expert Evaluators with Our Trusted Services
        </h1>
        <p class="hero-sub">
          We provide professional credential evaluation services for international students
          and professionals seeking U.S. recognition — ensuring your qualifications are
          accepted regardless of your country of origin.
        </p>
        <div class="hero-actions">
          <a href="/contact" class="btn btn-primary">Apply Now</a>
          <a href="/about" class="btn btn-outline">Learn More</a>
        </div>
      </div>
      <div class="hero-image-wrap">
        <div class="hero-img-ph">
          <img src="/home/Home-Hero-Img.webp" alt="True Evaluators credential evaluation services" class="hero-real-img" />
        </div>
        <!-- Floating badge -->
        <div class="hero-badge">
          <span class="hero-badge-num">100+</span>
          <span class="hero-badge-txt">Satisfied Clients</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 2 — GUIDING VALUES
       ============================================================ -->
  <section class="values section-pad">
    <div class="container">
      <div class="values-header">
        <div class="values-header-left">
          <span class="eyebrow">New Era Pulse</span>
          <h2>True Evaluators' Guiding Values<br class="br-desktop"/> in a Decade of Words</h2>
        </div>
        <p class="values-intro">
          Our evaluations are built on a decade of integrity, innovation, and excellence —
          committed to straightforward assessments you can rely on.
        </p>
      </div>

      <div class="values-grid">
        <!-- Card 1 -->
        <div class="value-card">
          <div class="value-icon icon-circle" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>Honesty First</h3>
          <p>
            We believe in always doing the right thing. Our evaluations are built on truth,
            transparency, and straightforward assessments.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="value-card">
          <div class="value-icon icon-circle" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3>Putting You First</h3>
          <p>
            The focus is on you. We want to understand your needs and deliver solutions
            that help you reach your academic and professional goals.
          </p>
        </div>

        <!-- Card 3 — dark accent -->
        <div class="value-card value-card-dark">
          <div class="value-icon-dark" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="2" width="28" height="28">
              <circle cx="12" cy="12" r="10"/>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
          <h3>Smart Solutions, Always</h3>
          <p>
            We use our expertise and accumulated knowledge to provide the best possible
            evaluation service — smart, timely, and precise.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 3 — TRUSTED PARTNER
       ============================================================ -->
  <section class="trusted section-pad" style="background: var(--clr-bg-light);">
    <div class="container grid-2-col">
      <!-- Image -->
      <div class="trusted-img-wrap">
        <div class="trusted-img">
          <img src="/home/Home-Trusted-Partner-Sec.webp" alt="Trusted partner for credential evaluations" class="trusted-real-img" />
        </div>
        <!-- Floating accent -->
        <div class="trusted-accent">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" width="28" height="28">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span>NACES Member</span>
        </div>
      </div>

      <!-- Text -->
      <div class="trusted-content">
        <span class="eyebrow">Our Mission</span>
        <h2>Trusted Partner for Professional Credential Evaluations</h2>
        <div class="divider"></div>
        <p>
          At True Evaluators, we recognize the significance of credential evaluation in an
          international context. With comprehensive services and expert evaluators, we make
          the process simple and reliable.
        </p>
        <p style="margin-top: 1rem;">
          Credentialing is the first step for educators in international mobility across the
          globe. Our dedicated team is committed to providing comprehensive evaluation services,
          offering the support and accuracy essential for thriving in a highly competitive
          landscape.
        </p>
        <a href="/about" class="btn btn-primary" style="margin-top: 2rem;">Read More</a>

        <!-- Stats -->
        <div class="stats-grid">
          <div class="stat-item">
            <span class="stat-number">5+</span>
            <span class="stat-label">Years Experience</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">10+</span>
            <span class="stat-label">Trusted Partners</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">95%</span>
            <span class="stat-label">Problem Solved</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">100+</span>
            <span class="stat-label">Satisfied Clients</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 4 — SERVICES
       ============================================================ -->
  <section class="services-sec section-pad" style="background: var(--clr-bg-cream);">
    <div class="container">
      <div class="services-top">
        <!-- Left: intro -->
        <div class="services-intro">
          <span class="eyebrow">Why Us</span>
          <h2>Everything We Offer is Designed to Help You Create a Business &amp; Life You Love</h2>
          <p>
            True Evaluators: Your Trusted Partner for Comprehensive Credential Evaluation Services.
            From education and professional licensure to immigration and employment.
          </p>
          <a href="/services" class="btn btn-primary" style="margin-top: 1.5rem;">All Services</a>
        </div>

        <!-- Right: service cards grid -->
        <div class="services-cards">
          {[
            {
              icon: `<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>`,
              title: 'Academic Evaluation',
              desc: 'Comprehensive evaluation of your academic qualifications for U.S. educational institutions and employers.',
              href: '/services/academic-evaluation',
            },
            {
              icon: `<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
              title: 'Work Experience Evaluation',
              desc: 'Expert assessment of your international work experience to meet U.S. visa and employment standards.',
              href: '/services/work-experience-evaluation',
            },
            {
              icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>`,
              title: 'Expert Opinion Letter',
              desc: 'Specialized letters from industry experts supporting H-1B visa petitions and professional immigration.',
              href: '/services/expert-opinion-letter',
            },
            {
              icon: `<circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>`,
              title: 'LCA Analysis FOR H-1B RFE',
              desc: 'When it comes to H-1B visa applications, getting things right is crucial. One essential component is the Labor Condition Application (LCA).',
              href: '/services/lca-analysis',
            },
            {
              icon: `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>`,
              title: 'CPT Analysis for H-1B',
              desc: 'Alternatives for H-1B visa analysis covering work authorization and Curricular Practical Training assessments.',
              href: '/services/cpt-analysis',
            },
            {
              icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
              title: 'Integrated Expert Opinion',
              desc: 'The service encompasses an integrated expert evaluation combining academic qualifications, coupled with work experience.',
              href: '/services/integrated-expert-opinion',
            },
          ].map(s => (
            <a href={s.href} class="service-card">
              <div class="service-card-icon icon-circle" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" set:html={s.icon} />
              </div>
              <h4>{s.title}</h4>
              <p>{s.desc}</p>
              <span class="service-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>

      <!-- RFE Card (wide) -->
      <div class="rfe-card">
        <div class="rfe-content">
          <div class="icon-circle" aria-hidden="true" style="background: rgba(255,255,255,0.15); width:56px; height:56px;">
            <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.9)" stroke-width="2" width="24" height="24">
              <path d="M9 12l2 2 4-4"/><path d="M21 12c0 1.2-.504 2.3-1.35 3.1a4.5 4.5 0 0 1-3.15 1.4 4.5 4.5 0 0 1-3.15-1.4A4.5 4.5 0 0 1 12 12a4.5 4.5 0 0 1 1.35-3.1A4.5 4.5 0 0 1 16.5 7.5a4.5 4.5 0 0 1 3.15 1.4A4.5 4.5 0 0 1 21 12z"/>
              <path d="M3 12h3M3 6h9M3 18h9"/>
            </svg>
          </div>
          <div>
            <h3 style="color: white;">Request for Evidence (RFE)</h3>
            <p style="color: rgba(255,255,255,0.75); margin-top: 0.5rem;">
              Form submission of RFE. Reason for submission is to comply, along with the
              comprehensive assessment of all required documents. Typically it includes all
              the necessary evaluation of the submitted documents.
            </p>
          </div>
        </div>
        <a href="/services/rfe" class="btn btn-outline-white" style="flex-shrink:0;">Learn More</a>
      </div>

    </div>
  </section>

  <!-- ============================================================
       SECTION 5 — EXPERTISE (dark)
       ============================================================ -->
  <section class="expertise section-pad" style="background: var(--clr-primary-dark);">
    <div class="container grid-2-col">
      <!-- Image -->
      <div class="expertise-img-wrap">
        <div class="expertise-img">
          <img src="/home/Our-Expertise-Img.jpg" alt="Our expertise in credential evaluations" class="expertise-real-img" />
        </div>
      </div>

      <!-- Content -->
      <div class="expertise-content">
        <span class="eyebrow" style="color: rgba(255,255,255,0.6);">What We Do Best</span>
        <h2 style="color: white;">Our Expertise in Specialized Services</h2>
        <div class="divider"></div>
        <p style="color: rgba(255,255,255,0.7);">
          Our services empower you to advance in your professional journey, securing certificates,
          jobs, and a distinct advantage over other candidates. Our assessments are instrumental
          in meeting the criteria for licenses, certifications, immigration processes, employment
          opportunities, and admission to American colleges.
        </p>
        <ul class="expertise-list">
          {[
            'Academic Evaluation',
            'Work Experience Evaluation',
            'Beneficiary Qualification Letter',
            'Expert Opinion Letter',
            'ECA Analysis',
            'CPT Analysis',
            'Integrated Expert Opinion',
            'Request for Evidence (RFE)',
          ].map(item => (
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--clr-primary)" stroke-width="2.5" width="16" height="16" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
        <a href="/services" class="btn btn-primary" style="margin-top: 2rem;">Get Evaluate Now</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 6 — PURPOSES
       ============================================================ -->
  <section class="purposes section-pad">
    <div class="container">
      <div class="purposes-header">
        <div>
          <span class="eyebrow">My Mission</span>
          <h2>Purposes of Credential Evaluation</h2>
          <p>
            Our evaluations serve four key purposes — each addressed with expertise
            and precision to meet your individual needs.
          </p>
        </div>
        <a href="/contact" class="btn btn-primary purposes-cta">Get Evaluate Now</a>
      </div>

      <div class="purposes-grid grid-auto-4" style="margin-top: 3rem;">
        {[
          {
            icon: `<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
            title: 'Employment',
            desc: 'Credential evaluation reports are valuable tools for employers across U.S. industries. Our comprehensive reports give employers a complete picture of your qualifications.',
          },
          {
            icon: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
            title: 'Healthcare',
            desc: 'We\'ve helped the initial steps Unite States healthcare professional program to meet strict credentialing requirements. Evaluations can help in licensing and hiring decisions.',
          },
          {
            icon: `<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>`,
            title: 'Education',
            desc: 'Education is the cornerstone to increasing access to Number U.S. schools. Our evaluations help you get into the academic institutions you want, be it college or university.',
          },
          {
            icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
            title: 'Military',
            desc: 'Military is an important medium for H-1B-based military service. Internationally Educated Evaluators make it easy to study in such a place as one.',
          },
        ].map(p => (
          <div class="purpose-card">
            <div class="icon-circle purpose-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" set:html={p.icon} />
            </div>
            <h4>{p.title}</h4>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 7 — BLOG
       ============================================================ -->
  <section class="blog-sec section-pad" style="background: var(--clr-bg-light);">
    <div class="container">
      <div class="blog-header">
        <div>
          <span class="eyebrow">My Website</span>
          <h2>Explore Our Latest Blog &amp; Articles</h2>
        </div>
        <a href="/blog" class="btn btn-outline">View All Posts</a>
      </div>

      <div class="blog-grid" style="margin-top: 2.5rem;">
        <article class="blog-card">
          <a href="/blog/how-to-handle-h1b-rfe" class="blog-card-img-wrap" tabindex="-1" aria-hidden="true">
            <img src="/home/How-to-handle-an-H-1B-RFE.webp" alt="How to handle an H-1B RFE" class="blog-card-img" />
          </a>
          <div class="blog-card-body">
            <time class="blog-date">December 11, 2023</time>
            <h4 class="blog-card-title">
              <a href="/blog/how-to-handle-h1b-rfe">How to handle an H-1B RFE?</a>
            </h4>
            <a href="/blog/how-to-handle-h1b-rfe" class="blog-read-more">→ Read More</a>
          </div>
        </article>

        <article class="blog-card">
          <a href="/blog/how-evaluations-help-h1b-rfe" class="blog-card-img-wrap" tabindex="-1" aria-hidden="true">
            <img src="/home/How-evaluations-help-in-responding-an-H-1B-RFE.webp" alt="How evaluations help in responding an H-1B RFE" class="blog-card-img" />
          </a>
          <div class="blog-card-body">
            <time class="blog-date">December 11, 2023</time>
            <h4 class="blog-card-title">
              <a href="/blog/how-evaluations-help-h1b-rfe">How evaluations help in responding an H-1B RFE?</a>
            </h4>
            <a href="/blog/how-evaluations-help-h1b-rfe" class="blog-read-more">→ Read More</a>
          </div>
        </article>

        <article class="blog-card">
          <a href="/blog/what-to-check-evaluator-report" class="blog-card-img-wrap" tabindex="-1" aria-hidden="true">
            <img src="/home/What-to-check-while-identifying-an-evaluator-for-a-evaluation-report.webp" alt="What to check while identifying an evaluator for a evaluation report" class="blog-card-img" />
          </a>
          <div class="blog-card-body">
            <time class="blog-date">December 11, 2023</time>
            <h4 class="blog-card-title">
              <a href="/blog/what-to-check-evaluator-report">What to check while identifying an evaluator for a evaluation report</a>
            </h4>
            <a href="/blog/what-to-check-evaluator-report" class="blog-read-more">→ Read More</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 8 — FOOTER CTA BANNER
       ============================================================ -->
  <section class="cta-banner section-pad" style="background: var(--clr-bg-cream);">
    <div class="container cta-banner-inner">
      <div>
        <span class="eyebrow">Get Started Today</span>
        <h2>True Evaluators Credential Evaluations</h2>
        <p>
          Ready to take the next step? Our expert team is here to guide you through
          the entire credential evaluation process with clarity and confidence.
        </p>
      </div>
      <div class="cta-banner-actions">
        <a href="/contact" class="btn btn-primary">Get Evaluate Now</a>
        <a href="/services" class="btn btn-outline">Our Services</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ============================================================
   HERO
   ============================================================ */
.hero {
  background: var(--clr-bg-cream);
  overflow: hidden;
}
.hero-inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
  align-items: center;
  padding-block: clamp(3rem, 7vw, 5.5rem);
}
@media (min-width: 768px) {
  .hero-inner { grid-template-columns: 1fr 1fr; }
}

.hero-content { max-width: 580px; }
.hero-heading {
  margin-top: 0.5rem;
  margin-bottom: 1.25rem;
  font-size: clamp(2.1rem, 5vw, 3.5rem);
}
.hero-sub {
  font-size: 1.02rem;
  line-height: 1.75;
  margin-bottom: 2rem;
}
.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.hero-image-wrap {
  position: relative;
  display: flex;
  justify-content: center;
}
.hero-img-ph {
  width: 100%;
  max-width: 520px;
  aspect-ratio: 4/3;
  border-radius: var(--radius-xl);
  overflow: hidden;
}
.hero-real-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: var(--radius-xl);
}

.hero-badge {
  position: absolute;
  bottom: 1.5rem;
  left: -1rem;
  background: var(--clr-white);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  padding: 0.75rem 1.1rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100px;
}
.hero-badge-num {
  font-family: var(--font-heading);
  font-size: 1.75rem;
  font-weight: 700;
  color: var(--clr-primary);
  line-height: 1;
}
.hero-badge-txt {
  font-size: 0.7rem;
  color: var(--clr-text-body);
  text-align: center;
  margin-top: 2px;
}

/* ============================================================
   GUIDING VALUES
   ============================================================ */
.values-header {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  margin-bottom: 3rem;
}
@media (min-width: 768px) {
  .values-header {
    grid-template-columns: 1fr 1fr;
    align-items: end;
  }
}
.values-intro {
  font-size: 1rem;
  max-width: 480px;
}
.br-desktop { display: none; }
@media (min-width: 768px) { .br-desktop { display: block; } }

.values-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}
@media (min-width: 640px) {
  .values-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1024px) {
  .values-grid { grid-template-columns: repeat(3, 1fr); }
}

.value-card {
  background: var(--clr-white);
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-lg);
  padding: 2rem;
  transition: transform var(--ease), box-shadow var(--ease);
}
.value-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}
.value-card-dark {
  background: var(--clr-primary-dark);
  border-color: var(--clr-primary-dark);
}
.value-card-dark h3 { color: white; }
.value-card-dark p  { color: rgba(255,255,255,0.7); }

.value-icon { margin-bottom: 1.25rem; }
.value-icon-dark {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
}
.value-card h3 { font-size: 1.25rem; margin-bottom: 0.6rem; }
.value-card p  { font-size: 0.88rem; line-height: 1.7; }

/* ============================================================
   TRUSTED PARTNER
   ============================================================ */
.trusted-img-wrap {
  position: relative;
  display: flex;
  justify-content: center;
}
.trusted-img {
  width: 100%;
  max-width: 480px;
  aspect-ratio: 4/5;
  border-radius: var(--radius-xl);
  overflow: hidden;
}
.trusted-real-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: var(--radius-xl);
}
.trusted-accent {
  position: absolute;
  bottom: 1.5rem;
  right: -0.5rem;
  background: var(--clr-primary);
  color: white;
  border-radius: var(--radius-md);
  padding: 0.65rem 1rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.78rem;
  font-weight: 600;
  box-shadow: var(--shadow-teal);
}

.trusted-content {}
.trusted-content p { font-size: 0.94rem; }

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
  margin-top: 2.5rem;
  padding-top: 2rem;
