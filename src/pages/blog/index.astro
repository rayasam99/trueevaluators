---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: 'how-to-handle-h1b-rfe',
    title: 'How to handle an H-1B RFE?',
    date: 'December 11, 2023',
    img: '/home/How-to-handle-an-H-1B-RFE.webp',
  },
  {
    slug: 'how-evaluations-help-h1b-rfe',
    title: 'How evaluations help in responding an H-1B RFE?',
    date: 'December 11, 2023',
    img: '/home/How-evaluations-help-in-responding-an-H-1B-RFE.webp',
  },
  {
    slug: 'what-to-check-evaluator-report',
    title: 'What to check while identifying an evaluator for a evaluation report',
    date: 'December 11, 2023',
    img: '/home/What-to-check-while-identifying-an-evaluator-for-a-evaluation-report.webp',
  },
];
---

<Layout
  title="Blog – True Evaluators"
  description="Dive into our blog for insightful articles covering the latest trends, expert opinions, and valuable tips in immigration, education, and career advancement."
>

  <!-- ── HERO ── -->
  <section class="inner-hero">
    <div class="container" style="text-align:center;">
      <h1>Explore Our Latest Blog &amp; Articles</h1>
      <p class="hero-sub">
        Dive into our blog for insightful articles covering the latest trends, expert
        opinions, and valuable tips in immigration, education, and career advancement.
        Stay informed and inspired with True Evaluators.
      </p>
    </div>
  </section>

  <!-- ── BLOG CARDS ── -->
  <section class="section-pad" style="background:var(--clr-bg-light);">
    <div class="container blog-grid">
      {posts.map(post => (
        <article class="blog-card">
          <a href={`/blog/${post.slug}`} class="blog-card-img-wrap" tabindex="-1" aria-hidden="true">
            <img src={post.img} alt={post.title} class="blog-card-img" />
          </a>
          <div class="blog-card-body">
            <time class="blog-date">{post.date}</time>
            <h2 class="blog-card-title">
              <a href={`/blog/${post.slug}`}>{post.title}</a>
            </h2>
            <a href={`/blog/${post.slug}`} class="blog-read-more">→ Read More</a>
          </div>
        </article>
      ))}
    </div>
  </section>

</Layout>

<style>
.inner-hero { background:var(--clr-bg-cream); padding-block:clamp(3rem,6vw,6rem); }
.inner-hero h1 { color:var(--clr-primary); font-size:clamp(1.8rem,4vw,2.8rem); }
.hero-sub { max-width:560px; margin-inline:auto; margin-top:1rem; font-size:0.92rem; }

.blog-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}
@media (min-width: 640px) {
  .blog-grid { grid-template-columns: repeat(2, 1fr); }
}

.blog-card {
  background: var(--clr-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--clr-border);
  display: flex;
  flex-direction: row;
  transition: transform var(--ease), box-shadow var(--ease);
}
.blog-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}
.blog-card-img-wrap {
  display: block;
  flex-shrink: 0;
  width: 260px;
}
.blog-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.blog-card-body {
  padding: 1.5rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.blog-date {
  font-size: 0.78rem;
  color: var(--clr-text-muted);
}
.blog-card-title {
  font-size: 1rem;
  font-family: var(--font-body);
  font-weight: 600;
  color: var(--clr-text-dark);
  line-height: 1.45;
  flex: 1;
}
.blog-card-title a { color: inherit; text-decoration: none; }
.blog-card-title a:hover { color: var(--clr-primary); }
.blog-read-more {
  font-size: 0.85rem;
  color: var(--clr-primary);
  text-decoration: none;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  margin-top: 0.25rem;
}
.blog-read-more:hover { text-decoration: underline; }
</style>
