---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Document List – True Evaluators"
  description="Discover the required documents for seamless credential evaluation processes with True Evaluators. Academic and Experience evaluation checklists."
>

  <!-- ── HERO ── -->
  <section class="inner-hero">
    <div class="container" style="text-align:center;">
      <h1>Navigating Your Path to Success</h1>
      <p class="hero-sub">
        Discover the required documents for seamless processes, ensuring
        precision and compliance in your immigration and credential evaluation
        journey with True Evaluators.
      </p>
    </div>
  </section>

  <!-- ── DOCUMENT CHECKLISTS ── -->
  <section class="section-pad">
    <div class="container doclist-grid">

      <!-- Academic Evaluation -->
      <div class="doclist-col">
        <h2>Academic Evaluation</h2>
        <ul class="checklist">
          {[
            'RFE copy, if any',
            'Copies of Degree/Diploma Certificates, Transcripts, Postgraduate Degree &amp; Marks sheets',
            'Certified English Translations if academic documents are in a foreign language.',
            'First page of the Passport',
          ].map(item => (
            <li class="checklist-item">
              <span class="check-icon" aria-hidden="true">
                <svg viewBox="0 0 20 20" fill="none" width="18" height="18">
                  <circle cx="10" cy="10" r="9" fill="var(--clr-primary-light)" stroke="var(--clr-primary)" stroke-width="1.2"/>
                  <path d="M6 10l3 3 5-6" stroke="var(--clr-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span set:html={item}></span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Experience Evaluation -->
      <div class="doclist-col">
        <h2>Experience Evaluation</h2>
        <ul class="checklist">
          {[
            'RFE copy, if any',
            'Copies of Degree/Diploma Certificates, Transcripts, Postgraduate Degree &amp; Marks sheets',
            'Certified English Translations if academic documents are in a foreign language.',
            'Experience letters from all the organizations',
            'Joining and Relieving documents',
            'First page of the Passport',
          ].map(item => (
            <li class="checklist-item">
              <span class="check-icon" aria-hidden="true">
                <svg viewBox="0 0 20 20" fill="none" width="18" height="18">
                  <circle cx="10" cy="10" r="9" fill="var(--clr-primary-light)" stroke="var(--clr-primary)" stroke-width="1.2"/>
                  <path d="M6 10l3 3 5-6" stroke="var(--clr-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span set:html={item}></span>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </section>

</Layout>

<style>
.inner-hero {
  background: var(--clr-bg-cream);
  padding-block: clamp(3rem, 6vw, 5rem);
}
.inner-hero h1 {
  color: var(--clr-primary);
  font-size: clamp(1.8rem, 4vw, 2.8rem);
}
.hero-sub {
  max-width: 580px;
  margin-inline: auto;
  margin-top: 1rem;
  font-size: 0.95rem;
  text-align: center;
}

.doclist-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
}
@media (min-width: 768px) { .doclist-grid { grid-template-columns: 1fr 1fr; gap: 4rem; } }

.doclist-col h2 {
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  margin-bottom: 1.75rem;
  color: var(--clr-text-dark);
}

.checklist {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  list-style: none;
}
.checklist-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  font-size: 0.92rem;
  color: var(--clr-primary);
  line-height: 1.5;
}
.check-icon { flex-shrink: 0; margin-top: 1px; }
</style>
