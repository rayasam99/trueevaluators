---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Academic Evaluation – True Evaluators"
  description="True Evaluators is the top global provider of Academic Evaluation services. Comprehensive evaluations for U.S. educational institutions and employers."
>

  <!-- ── HERO ── -->
  <section class="inner-hero">
    <div class="container" style="text-align:center;">
      <h1>Academic Evaluation</h1>
    </div>
  </section>

  <!-- ── DUAL IMAGES ── -->
  <section style="background:var(--clr-bg-cream);padding-bottom:clamp(2rem,4vw,3.5rem);">
    <div class="container dual-imgs">
      <img src="/Academic-Evaluation/Academic-Evaluation-Img-2.webp" alt="Academic Evaluation" class="dual-img-main" />
      <img src="/Academic-Evaluation/Academic-Evaluation-Img-1.webp" alt="Academic Evaluation services" class="dual-img-side" />
    </div>
  </section>

  <!-- ── MAIN CONTENT ── -->
  <section class="section-pad">
    <div class="container main-grid">

      <!-- Left -->
      <div>
        <span class="eyebrow">
          <svg viewBox="0 0 14 14" fill="none" width="10" height="10" aria-hidden="true" style="display:inline-block;vertical-align:middle;margin-right:4px;">
            <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          True Evaluation
        </span>
        <h2 style="margin-top:0.6rem;">Academic Evaluation Services</h2>

        <p class="docs-label" style="margin-top:1.25rem;">Documents Required</p>
        <ul class="checklist" style="margin-top:0.75rem;">
          {[
            'Secondary and Higher Secondary School Certificates (Equivalent to High School in the American Education System)',
            'Transcripts and Degree Certificates for all Academic Degrees',
          ].map(item => (
            <li class="checklist-item">
              <span class="check-icon" aria-hidden="true">
                <svg viewBox="0 0 20 20" fill="none" width="18" height="18">
                  <circle cx="10" cy="10" r="9" fill="var(--clr-primary-light)" stroke="var(--clr-primary)" stroke-width="1.2"/>
                  <path d="M6 10l3 3 5-6" stroke="var(--clr-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="check-text">{item}</span>
            </li>
          ))}
        </ul>

        <a href="/contact" class="btn btn-primary" style="margin-top:1.75rem;">Get Evaluate Now</a>
      </div>

      <!-- Right -->
      <div class="main-text">
        <p>
          True Evaluators is the top global provider of Academic Evaluation services.
          We create detailed reports to determine how a candidate's foreign academic and
          professional credentials compare to the US educational system. Our evaluations
          are well-regarded by the US Citizenship and Immigration Services, the US Labor
          Department, professional advisory boards, international academic advisory
          organizations, and American universities.
        </p>
        <p style="margin-top:1rem;">
          Our Academic Evaluation services look into the candidate's foreign educational
          credentials. We consider the level of education, years of study, and the specific
          field of specialization. Factors like the foreign country's educational system,
          the quality of the candidate's university, credit hours, duration of coursework,
          course nature, and grades are taken into account.
        </p>
        <p style="margin-top:1rem;">
          What makes True Evaluators stand out is the quality of our evaluation content.
          Each evaluation includes a thorough review of the candidate's credentials, a
          discussion on completed university programs and courses, and a detailed analysis
          of how the foreign credentials match up with US educational standards. We provide
          transparency by sharing the principal reference sources used by our evaluators
          and their resumes.
        </p>
      </div>
    </div>
  </section>

  <!-- ── PROCESS ── -->
  <section class="section-pad" style="background:var(--clr-bg-light);padding-top:0;">
    <div class="container process-layout">

      <!-- Left intro -->
      <div class="process-intro">
        <span class="eyebrow">
          <svg viewBox="0 0 14 14" fill="none" width="10" height="10" aria-hidden="true" style="display:inline-block;vertical-align:middle;margin-right:4px;">
            <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          Our Process
        </span>
        <p style="margin-top:0.6rem;font-size:0.88rem;line-height:1.7;">
          True Evaluators: Your Trusted Partner for Comprehensive Credential Evaluation Services.
          From education and professional licensure to immigration and employment.
        </p>
      </div>

      <!-- Steps -->
      <div class="process-steps">
        <div class="step-card step-card-highlight">
          <h4>Preliminary Consultation</h4>
          <p>
            Commence the process by completing the online form, providing essential background
            details, academic objectives, and preferences for our services. Benefit from expert
            guidance to determine the most suitable service plan tailored to your specific needs.
          </p>
        </div>
        <div class="step-card">
          <h4>Document Collection</h4>
          <p>
            Select your service plan, receive a comprehensive document checklist, and promptly
            submit the necessary records for swift processing.
          </p>
        </div>
        <div class="step-card">
          <h4>Case Review and Preparation</h4>
          <p>
            A dedicated expert will meticulously evaluate, research, and compose a detailed,
            customized evaluation report. You will have the opportunity to review a draft before
            finalizing the report.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CONCLUSION ── -->
  <section class="section-pad">
    <div class="container conclusion-grid">
      <img src="/Academic-Evaluation/image-TFLS7QC.jpg" alt="Conclusion and Delivery" class="conclusion-img" />
      <div>
        <h2>Conclusion and Delivery</h2>
        <p style="margin-top:0.75rem;">
          Upon your approval, the final report will be delivered in PDF format. If preferred,
          you can opt for mail delivery for an additional fee. Our commitment to transparent
          communication ensures satisfaction at every stage of the process.
        </p>
        <a href="/contact" class="cta-link" style="margin-top:1.25rem;display:inline-flex;align-items:center;gap:0.4rem;color:var(--clr-primary);font-weight:600;font-size:0.9rem;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Get Evaluate Now
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
.inner-hero {
  background: var(--clr-bg-cream);
  padding-block: clamp(3rem, 6vw, 5rem);
}
.inner-hero h1 { color: var(--clr-primary); font-size: clamp(2rem, 5vw, 3rem); }

.dual-imgs {
  display: grid;
  grid-template-columns: 3fr 2fr;
  gap: 1rem;
}
@media (max-width:640px) { .dual-imgs { grid-template-columns: 1fr; } }
.dual-img-main { height: clamp(320px,40vw,520px); border-radius: var(--radius-lg); width: 100%; object-fit: cover; display: block; }
.dual-img-side { height: clamp(320px,40vw,520px); border-radius: var(--radius-lg); width: 100%; object-fit: cover; display: block; }

.main-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: start;
}
@media (min-width:768px) { .main-grid { grid-template-columns: 1fr 1.2fr; } }

.docs-label {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--clr-text-dark);
}
.checklist { list-style: none; display: flex; flex-direction: column; gap: 0.85rem; }
.checklist-item { display: flex; gap: 0.65rem; align-items: flex-start; }
.check-icon { flex-shrink: 0; margin-top: 1px; }
.check-text { font-size: 0.88rem; color: var(--clr-primary); line-height: 1.5; }
.main-text p { font-size: 0.9rem; }

/* Process */
.process-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  padding-top: clamp(2rem, 4vw, 3.5rem);
}
@media (min-width: 1024px) { .process-layout { grid-template-columns: 200px 1fr; } }

.process-steps {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}
@media (min-width: 640px) { .process-steps { grid-template-columns: repeat(3, 1fr); } }

.step-card {
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  background: var(--clr-white);
}
.step-card-highlight { background: var(--clr-bg-cream); border-color: #e8cec8; }
.step-card h4 { font-size: 0.95rem; margin-bottom: 0.6rem; font-family: var(--font-body); font-weight: 700; }
.step-card p  { font-size: 0.83rem; line-height: 1.65; }

/* Conclusion */
.conclusion-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
  align-items: center;
}
@media (min-width: 768px) { .conclusion-grid { grid-template-columns: 1fr 1fr; } }
.conclusion-img {
  width: 100%;
  aspect-ratio: 4/3;
  border-radius: var(--radius-lg);
  object-fit: cover;
  display: block;
}
</style>
