---
import Layout from '../../layouts/Layout.astro';

const docs = [
  'Copies of Degree/Diploma Certificates, Transcripts, and Postgraduate Degree/s.',
  'Certified English Translations for academic documents in a foreign language.',
  'Experience letters from current and previous employers, outlining periods of employment, job titles, and responsibilities.',
  'Comprehensive employer-based resume detailing job titles, employer names, duration of employment (month/year), and job responsibilities.',
  'Support Letter from the Petitioner.',
  'Request for Evidence (RFE), if applicable.',
  'Labor Condition Application (LCA) for the specified position.',
  'Detailed description of the job duties the beneficiary will undertake in the offered position.',
  'Academic documents pertaining to the beneficiary\'s qualifications.',
];
---

<Layout
  title="Integrated Expert Opinion – True Evaluators"
  description="This service encompasses an integrated expert opinion, incorporating both academic and professional evaluations of the beneficiary's qualifications."
>

  <!-- ── HERO ── -->
  <section class="inner-hero">
    <div class="container" style="text-align:center;">
      <h1>Integrated Expert Opinion</h1>
    </div>
  </section>

  <!-- ── CONTENT ── -->
  <section class="section-pad">
    <div class="container" style="max-width:860px;">
      <p>
        This service encompasses an integrated expert opinion, incorporating both academic
        and professional evaluations of the beneficiary's qualifications, coupled with an
        assessment of the specialized occupation position. This thorough expert analysis
        will be conducted by a faculty expert duly authorized to confer "college-level
        credits" or "life experience credits" for relevant work experience and training
        within the specified field. The expert will affirm the beneficiary's suitability
        based on the findings of the evaluation.
      </p>

      <h3 style="margin-top:2rem;margin-bottom:1rem;font-family:var(--font-body);font-weight:700;font-size:1rem;">
        Document Checklist:
      </h3>

      <ul class="checklist">
        {docs.map(doc => (
          <li class="checklist-item">
            <span class="check-icon" aria-hidden="true">
              <svg viewBox="0 0 20 20" fill="none" width="18" height="18">
                <circle cx="10" cy="10" r="9" fill="var(--clr-primary-light)" stroke="var(--clr-primary)" stroke-width="1.2"/>
                <path d="M6 10l3 3 5-6" stroke="var(--clr-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="check-text">{doc}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

</Layout>

<style>
.inner-hero { background:var(--clr-bg-cream); padding-block:clamp(3rem,6vw,5rem); }
.inner-hero h1 { color:var(--clr-primary); font-size:clamp(2rem,5vw,3rem); text-align:center; }
.checklist { list-style:none; display:flex; flex-direction:column; gap:1rem; }
.checklist-item { display:flex; gap:0.75rem; align-items:flex-start; }
.check-icon { flex-shrink:0; margin-top:2px; }
.check-text { font-size:0.92rem; color:var(--clr-primary); line-height:1.55; }
</style>
